## t/test_k8s.stk — assertion tests for the stryke `K8s` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_k8s.{dylib,so}` on
## `use K8s`. Live tests provision a unique namespace `stryke-test-$$` and
## tear it down at exit; requires a reachable cluster (KUBECONFIG /
## current-context).

use K8s

# ── permission-free: cdylib reachable ───────────────────────────────
val $pkg_version = K8s::pkg_version()
assert_ok $pkg_version, "K8s::pkg_version returns truthy (cdylib loaded)"

# ── cluster liveness + write-permission probe ───────────────────────
# Connected clusters without RBAC for namespace patch are common (GKE
# read-only auth); guard the live block so a forbidden apply doesn't
# pollute the test report — eval the probe and the whole block.
val $alive = eval { K8s::ping() && eval { K8s::apply({
    apiVersion => "v1", kind => "Namespace",
    metadata => { name => "stryke-test-probe-$$" },
}); K8s::delete_resource("namespace", "stryke-test-probe-$$"); 1 } }

if ($alive) {
    val $ns = "stryke-test-$$"

    # 1. apply Namespace
    val $ns_obj = K8s::apply({
        apiVersion => "v1",
        kind       => "Namespace",
        metadata   => { name => $ns, labels => { "stryke.io/test" => "1" } },
    })
    assert_eq $ns_obj->{metadata}{name}, $ns, "apply Namespace: name preserved"

    # 2. version
    val $v = K8s::version()
    assert_ok defined $v->{gitVersion}, "version returns gitVersion"

    # 3. apply ConfigMap
    val $cm = K8s::apply({
        apiVersion => "v1",
        kind       => "ConfigMap",
        metadata   => { name => "cfg", namespace => $ns },
        data       => { hello => "world", lang => "stryke" },
    })
    assert_eq $cm->{data}{hello}, "world", "apply ConfigMap: hello=world"

    # 4. get configmaps (list)
    val @cms = K8s::get("configmaps", namespace => $ns)
    val $found_cm = grep { $_->{metadata}{name} eq "cfg" } @cms
    assert_ok $found_cm, "get configmaps: includes cfg"

    # 5. get-one configmap
    val $one = K8s::get_one("configmaps", "cfg", namespace => $ns)
    assert_eq $one->{data}{lang}, "stryke", "get_one ConfigMap: data.lang"

    # 6. apply Deployment
    val $dep = K8s::apply({
        apiVersion => "apps/v1",
        kind       => "Deployment",
        metadata   => { name => "sleeper", namespace => $ns },
        spec       => {
            replicas => 1,
            selector => { matchLabels => { app => "sleeper" } },
            template => {
                metadata => { labels => { app => "sleeper" } },
                spec     => {
                    containers => [{
                        name    => "main",
                        image   => "busybox:latest",
                        command => ["sh", "-c", "sleep 3600"],
                    }],
                },
            },
        },
    })
    assert_ok defined $dep->{metadata}{name}, "apply Deployment: metadata.name present"

    # 7. scale Deployment to 2
    val $scaled = K8s::scale("deploy", "sleeper", 2, namespace => $ns)
    assert_eq $scaled->{spec}{replicas}, 2, "scale: replicas=2"

    # 8. api_resources includes core/v1/Pod
    val @ar = K8s::api_resources()
    val $found_pod = grep { $_->{kind} eq "Pod" && $_->{version} eq "v1" } @ar
    assert_ok $found_pod, "api_resources: includes core/v1/Pod"

    # 9. delete Namespace (cascades everything)
    val $del = K8s::delete_resource("namespace", $ns)
    assert_match qr/Deleting|Done/, $del->{status}, "delete Namespace: status Deleting/Done"
}

# ── pure helpers (no cluster — always run) ───────────────────────────
assert_ok K8s::valid_name("my-app.v2")->{valid}, "valid_name: subdomain accepts dots"
val $lbl = K8s::valid_name("my.app", mode => "label")
assert_eq $lbl->{valid}, 0, "valid_name: label mode rejects dots"
assert_eq K8s::valid_name("MyApp")->{valid}, 0, "valid_name: rejects uppercase"

# valid_label_value: label VALUE rules (distinct from names — empty/uppercase/_ ok).
assert_ok K8s::valid_label_value("")->{valid},           "valid_label_value: empty is valid"
assert_ok K8s::valid_label_value("Production")->{valid}, "valid_label_value: uppercase allowed"
assert_ok K8s::valid_label_value("v1.2.3")->{valid},     "valid_label_value: dots and digits"
assert_ok K8s::valid_label_value("my_value-1")->{valid}, "valid_label_value: underscore and dash allowed"
assert_eq K8s::valid_label_value("-bad")->{valid}, 0,    "valid_label_value: must start alphanumeric"
assert_eq K8s::valid_label_value("a b")->{valid}, 0,     "valid_label_value: rejects spaces"
val $tl = K8s::valid_label_value("a" x 64)
assert_eq $tl->{valid}, 0,                               "valid_label_value: over 63 chars fails"
assert_match qr/63/, $tl->{reason},                      "valid_label_value: reason names the limit"

# valid_label_key: label/annotation KEY rules (IsQualifiedName) — optional prefix.
assert_ok K8s::valid_label_key("app")->{valid},                     "valid_label_key: bare name"
val $lk = K8s::valid_label_key("app.kubernetes.io/name")
assert_ok $lk->{valid},                                             "valid_label_key: prefixed key valid"
assert_eq $lk->{prefix}, "app.kubernetes.io",                       "valid_label_key: prefix split out"
assert_eq $lk->{name},   "name",                                    "valid_label_key: name split out"
assert_eq K8s::valid_label_key("a/b/c")->{valid}, 0,               "valid_label_key: rejects two slashes"
assert_eq K8s::valid_label_key("UPPER.PREFIX/name")->{valid}, 0,   "valid_label_key: prefix must be lowercase DNS subdomain"
assert_eq K8s::valid_label_key("-bad")->{valid}, 0,                "valid_label_key: name must start alphanumeric"

val @reqs = K8s::parse_selector("app=nginx,tier!=frontend,!canary")
assert_eq scalar(@reqs), 3,            "parse_selector: three requirements"
assert_eq $reqs[0]{key}, "app",        "parse_selector: equality key"
assert_eq $reqs[0]{op},  "Equal",      "parse_selector: equality op"
assert_eq $reqs[1]{op},  "NotEqual",   "parse_selector: not-equal op"
assert_eq $reqs[2]{op},  "DoesNotExist", "parse_selector: !key existence"

val @setb = K8s::parse_selector("env in (prod,staging)")
assert_eq scalar(@setb), 1,                "parse_selector: paren comma stays together"
assert_eq $setb[0]{op}, "In",              "parse_selector: set-based In"
assert_eq scalar(@{ $setb[0]{values} }), 2, "parse_selector: two set values"

# build_selector: inverse of parse_selector across all operator forms.
val $sel = K8s::build_selector([
    +{ key => "app",  op => "Equal",    value  => "nginx" },
    +{ key => "tier", op => "NotEqual", value  => "frontend" },
    +{ key => "env",  op => "In",       values => ["prod", "staging"] },
    +{ key => "canary", op => "Exists" },
    +{ key => "legacy", op => "DoesNotExist" },
])
assert_eq $sel, "app=nginx,tier!=frontend,env in (prod,staging),canary,!legacy", "build_selector: all operator forms"
# Round-trips: build → parse reproduces the requirement count.
assert_eq scalar(@{ [ K8s::parse_selector($sel) ] }), 5, "build_selector → parse_selector round-trips"
assert_dies fn { K8s::build_selector([ +{ key => "x", op => "Bogus" } ]) }, "build_selector: rejects unknown op"

# parse_field_selector: field selectors support only =, ==, != (not set-based).
val @fs = K8s::parse_field_selector("status.phase!=Running,spec.restartPolicy=Always")
assert_eq scalar(@fs), 2,                   "parse_field_selector: two requirements"
assert_eq $fs[0]{field},    "status.phase", "parse_field_selector: field path"
assert_eq $fs[0]{operator}, "!=",           "parse_field_selector: inequality operator"
assert_eq $fs[1]{operator}, "=",            "parse_field_selector: equality operator"
assert_eq $fs[1]{value},    "Always",       "parse_field_selector: value"
assert_eq [ K8s::parse_field_selector("metadata.name==foo") ]->[0]{operator}, "=", "parse_field_selector: == normalizes to ="
assert_dies fn { K8s::parse_field_selector("env in (prod,staging)") }, "parse_field_selector: rejects set-based operators"
assert_dies fn { K8s::parse_field_selector("status.phase") },          "parse_field_selector: rejects a clause with no operator"

# build_field_selector: inverse of parse_field_selector, field-selector counterpart of build_selector.
val $fsel = "status.phase!=Running,spec.restartPolicy=Always"
assert_eq K8s::build_field_selector([ K8s::parse_field_selector($fsel) ]), $fsel, "build_field_selector: round-trips parse_field_selector"
assert_eq K8s::build_field_selector([ +{ field => "metadata.name" }, +{ field => "spec.nodeName", operator => "==", value => "node1" } ]), "metadata.name=,spec.nodeName=node1", "build_field_selector: operator defaults to =, == normalizes to ="
assert_dies fn { K8s::build_field_selector([ +{ field => "env", operator => "in", value => "prod" } ]) }, "build_field_selector: rejects set-based operators"
assert_dies fn { K8s::build_field_selector([ +{ field => "a,b", value => "x" } ]) },                      "build_field_selector: rejects a field with a comma"

# selector_matches: evaluate a label map against a selector (apimachinery rules).
val %pod = (app => "nginx", tier => "frontend", env => "prod")
assert_ok  K8s::selector_matches(\%pod, "app=nginx,env in (prod,staging)"), "selector_matches: all requirements satisfied"
assert_eq  K8s::selector_matches(\%pod, "app=nginx,env=dev"), 0,            "selector_matches: one failing requirement fails the selector"
assert_ok  K8s::selector_matches(\%pod, "tier!=backend"),                   "selector_matches: NotEqual with a different value"
assert_eq  K8s::selector_matches(\%pod, "tier!=frontend"), 0,              "selector_matches: NotEqual with the same value fails"
# absent-key rule: NotIn / NotEqual match a missing label; In does not.
assert_ok  K8s::selector_matches(\%pod, "missing notin (a,b)"),             "selector_matches: NotIn matches an absent key"
assert_eq  K8s::selector_matches(\%pod, "missing in (a,b)"), 0,            "selector_matches: In does not match an absent key"
assert_ok  K8s::selector_matches(\%pod, ""),                                "selector_matches: empty selector selects all"

# field_selector_matches: evaluate a field map against a FIELD selector (=, ==, != only).
val %obj = ("status.phase" => "Running", "spec.nodeName" => "node1")
assert_ok  K8s::field_selector_matches(\%obj, "status.phase=Running"),       "field_selector_matches: equality on a present field"
assert_eq  K8s::field_selector_matches(\%obj, "status.phase=Pending"), 0,    "field_selector_matches: wrong value fails"
assert_ok  K8s::field_selector_matches(\%obj, "status.phase!=Pending"),      "field_selector_matches: inequality"
assert_ok  K8s::field_selector_matches(\%obj, "spec.nodeName==node1"),       "field_selector_matches: == is equality"
assert_ok  K8s::field_selector_matches(\%obj, "metadata.name="),             "field_selector_matches: absent field equals the empty string"
assert_eq  K8s::field_selector_matches(\%obj, "status.phase=Running,spec.nodeName=node2"), 0, "field_selector_matches: requirements are ANDed"
assert_dies fn { K8s::field_selector_matches(\%obj, "status.phase in (Running)") }, "field_selector_matches: rejects set-based operators"

val $rr = K8s::parse_resource_ref("deployment/web")
assert_eq $rr->{kind}, "deployment", "parse_resource_ref: kind"
assert_eq $rr->{name}, "web",        "parse_resource_ref: name"

# build_resource_ref: inverse of parse_resource_ref.
assert_eq K8s::build_resource_ref("deployment", "web")->{ref}, "deployment/web", "build_resource_ref: kind/name"
assert_eq K8s::build_resource_ref("pods")->{ref}, "pods", "build_resource_ref: bare kind"
val $prr = K8s::parse_resource_ref("deployment/web")
assert_eq K8s::build_resource_ref($prr->{kind}, $prr->{name})->{ref}, "deployment/web", "build_resource_ref: round-trips parse_resource_ref"
assert_dies fn { K8s::build_resource_ref("") }, "build_resource_ref: rejects an empty kind"
assert_dies fn { K8s::build_resource_ref("pod", "a/b") }, "build_resource_ref: rejects a slash in the name"

# parse_api_version: split an apiVersion into group + version.
val $core = K8s::parse_api_version("v1")
assert_eq $core->{group},   "",   "parse_api_version: bare v1 has the empty (core) group"
assert_eq $core->{version}, "v1", "parse_api_version: bare v1 version"
assert_eq $core->{core},    1,    "parse_api_version: bare v1 is the core group"
val $apps = K8s::parse_api_version("apps/v1")
assert_eq $apps->{group},   "apps", "parse_api_version: group of apps/v1"
assert_eq $apps->{version}, "v1",   "parse_api_version: version of apps/v1"
assert_eq $apps->{core},    0,      "parse_api_version: apps/v1 is not core"
assert_eq K8s::parse_api_version("networking.k8s.io/v1")->{group}, "networking.k8s.io", "parse_api_version: dotted group kept"
assert_dies fn { K8s::parse_api_version("a/b/c") }, "parse_api_version: rejects more than one slash"
assert_dies fn { K8s::parse_api_version("apps/") }, "parse_api_version: rejects an empty version"
assert_dies fn { K8s::parse_api_version("/v1") },   "parse_api_version: rejects an empty group"

# build_api_version: inverse of parse_api_version.
assert_eq K8s::build_api_version("", "v1")->{api_version},        "v1",      "build_api_version: empty group → bare core form"
assert_eq K8s::build_api_version("apps", "v1")->{api_version},    "apps/v1", "build_api_version: group → group/version"
assert_eq K8s::build_api_version("apps", "v1")->{core},           0,         "build_api_version: grouped is not core"
assert_eq K8s::build_api_version(K8s::parse_api_version("apps/v1")->{group}, K8s::parse_api_version("apps/v1")->{version})->{api_version}, "apps/v1", "build_api_version: round-trips parse_api_version"
assert_dies fn { K8s::build_api_version("apps", "") },  "build_api_version: rejects an empty version"
assert_dies fn { K8s::build_api_version("a/b", "v1") }, "build_api_version: rejects a slash in the group"

# parse_quantity: binary memory, milli-CPU, decimal SI, bare/exponent numbers.
val $mem = K8s::parse_quantity("100Mi")
assert_eq $mem->{value},  104857600, "parse_quantity: 100Mi = 100*1024^2 bytes"
assert_eq $mem->{suffix}, "Mi",      "parse_quantity: binary suffix preserved"
val $cpu = K8s::parse_quantity("500m")
assert_eq $cpu->{value}, 0.5,        "parse_quantity: 500m = 0.5 cores"
assert_eq K8s::parse_quantity("2Gi")->{value}, 2147483648, "parse_quantity: 2Gi bytes"
assert_eq K8s::parse_quantity("1k")->{value},  1000,       "parse_quantity: decimal k = 1000"
assert_eq K8s::parse_quantity("1.5")->{value}, 1.5,        "parse_quantity: bare decimal"
assert_eq K8s::parse_quantity("1e3")->{value}, 1000,       "parse_quantity: exponent number"

# compare_quantity: order resource quantities across unit suffixes.
assert_eq K8s::compare_quantity("1Gi", "1024Mi")->{cmp}, 0,  "compare_quantity: 1Gi == 1024Mi"
assert_eq K8s::compare_quantity("500m", "0.5")->{cmp},   0,  "compare_quantity: 500m == 0.5 cores"
assert_eq K8s::compare_quantity("2Gi", "1Gi")->{cmp},    1,  "compare_quantity: 2Gi > 1Gi"
assert_eq K8s::compare_quantity("250m", "1")->{cmp},    -1,  "compare_quantity: 250m < 1 core"
assert_dies fn { K8s::compare_quantity("5Xi", "1") },        "compare_quantity: rejects an unknown suffix"

# format_quantity: inverse of parse_quantity.
assert_eq K8s::format_quantity(104857600, "Mi")->{quantity}, "100Mi", "format_quantity: explicit Mi suffix"
assert_eq K8s::format_quantity(0.5, "m")->{quantity},        "500m",  "format_quantity: milli-CPU"
assert_eq K8s::format_quantity(104857600)->{quantity},      "100Mi", "format_quantity: auto-picks largest binary suffix"
assert_eq K8s::format_quantity(100)->{quantity},            "100",   "format_quantity: bare number when no binary divisor"
# round-trip back through parse_quantity.
assert_eq K8s::parse_quantity(K8s::format_quantity(2147483648)->{quantity})->{value}, 2147483648, "format_quantity → parse_quantity round-trips 2Gi"
assert_dies fn { K8s::format_quantity(1, "Xi") }, "format_quantity: rejects unknown suffix"

# sum_quantities: total a list of quantities across units.
val $sum = K8s::sum_quantities("100Mi", "256Mi", "128Mi")
assert_eq $sum->{count}, 3,          "sum_quantities: counts the inputs"
assert_eq $sum->{quantity}, "484Mi", "sum_quantities: 484Mi total rendered compactly"
assert_eq K8s::sum_quantities("1Gi", "1024Mi")->{quantity}, "2Gi", "sum_quantities: cross-unit 1Gi+1024Mi=2Gi"
assert_eq K8s::sum_quantities("500m", "0.5", "250m")->{value}, 1.25, "sum_quantities: CPU cores total"
assert_dies fn { K8s::sum_quantities() }, "sum_quantities: rejects an empty list"
assert_dies fn { K8s::sum_quantities("100Xi") }, "sum_quantities: rejects an unknown suffix"

# sub_quantity: pairwise headroom (a - b), the companion to sum_quantities.
val $hr = K8s::sub_quantity("8Gi", "2Gi")
assert_eq $hr->{quantity}, "6Gi",    "sub_quantity: 8Gi - 2Gi = 6Gi (keeps a's suffix)"
assert_eq $hr->{negative}, 0,        "sub_quantity: positive headroom is not negative"
assert_eq K8s::sub_quantity("1Gi", "512Mi")->{quantity}, "0.5Gi", "sub_quantity: cross-unit 1Gi - 512Mi = 0.5Gi"
assert_eq K8s::sub_quantity("8Gi", "1536Mi", "Mi")->{quantity}, "6656Mi", "sub_quantity: explicit suffix renders in Mi"
val $over = K8s::sub_quantity("1Gi", "2Gi")
assert_eq $over->{negative}, 1,      "sub_quantity: over-allocation reports negative (not clamped)"
assert_dies fn { K8s::sub_quantity("1Gi", "1Xi") }, "sub_quantity: rejects an unknown suffix"

# scale_quantity: multiply a quantity by a scalar (replicas × per-pod request).
val $scaled = K8s::scale_quantity("256Mi", 3)
assert_eq $scaled->{quantity}, "768Mi", "scale_quantity: 256Mi×3=768Mi keeps the unit"
assert_eq $scaled->{factor}, 3,         "scale_quantity: echoes the factor"
assert_eq K8s::scale_quantity("2Gi", 3)->{quantity}, "6Gi",     "scale_quantity: 2Gi×3=6Gi"
assert_eq K8s::scale_quantity("500m", 2)->{quantity}, "1000m",  "scale_quantity: 500m×2=1000m"
assert_eq K8s::scale_quantity("2Gi", 0.5)->{quantity}, "1Gi",   "scale_quantity: fractional factor 2Gi×0.5=1Gi"
assert_eq K8s::scale_quantity("1Gi", 2, "Mi")->{quantity}, "2048Mi", "scale_quantity: explicit suffix renders in Mi"
# Cross-check against compare_quantity: 256Mi×4 == 1Gi.
assert_eq K8s::compare_quantity(K8s::scale_quantity("256Mi", 4)->{quantity}, "1Gi")->{cmp}, 0,
    "scale_quantity: 256Mi×4 equals 1Gi"
assert_dies fn { K8s::scale_quantity("100Xi", 2) }, "scale_quantity: rejects an unknown suffix"

# parse_gvk: GroupVersionKind triple / two-part / bare forms.
val $gvk = K8s::parse_gvk("apps/v1/Deployment")
assert_eq $gvk->{group},   "apps",       "parse_gvk: group"
assert_eq $gvk->{version}, "v1",         "parse_gvk: version"
assert_eq $gvk->{kind},    "Deployment", "parse_gvk: kind"
assert_eq $gvk->{core},    0,            "parse_gvk: grouped is not core"
assert_eq K8s::parse_gvk("v1/Pod")->{core}, 1,    "parse_gvk: version/kind is the core group"
assert_eq K8s::parse_gvk("Pod")->{kind},    "Pod", "parse_gvk: bare kind"
assert_dies fn { K8s::parse_gvk("a/b/c/d") }, "parse_gvk: rejects more than three segments"
assert_dies fn { K8s::parse_gvk("apps/v1/") }, "parse_gvk: rejects an empty kind"

# build_gvk: inverse of parse_gvk.
assert_eq K8s::build_gvk("Deployment", "v1", "apps")->{gvk}, "apps/v1/Deployment", "build_gvk: full triple"
assert_eq K8s::build_gvk("Pod", "v1")->{gvk}, "v1/Pod", "build_gvk: version/kind"
assert_eq K8s::build_gvk("Pod")->{gvk}, "Pod", "build_gvk: bare kind"
val $pgvk = K8s::parse_gvk("batch/v1/Job")
assert_eq K8s::build_gvk($pgvk->{kind}, $pgvk->{version}, $pgvk->{group})->{gvk}, "batch/v1/Job", "build_gvk: round-trips parse_gvk"
assert_dies fn { K8s::build_gvk("") }, "build_gvk: rejects an empty kind"

# parse_image_ref: registry / repository / tag / digest split.
val $img = K8s::parse_image_ref("registry.example.com:5000/team/app:v2")
assert_eq $img->{registry},   "registry.example.com:5000", "parse_image_ref: registry host with port"
assert_eq $img->{repository}, "team/app",                  "parse_image_ref: repository path"
assert_eq $img->{tag},        "v2",                        "parse_image_ref: tag (not the registry port)"
assert_eq K8s::parse_image_ref("nginx:1.27")->{registry}, "", "parse_image_ref: Hub short name has no registry"
val $dg = K8s::parse_image_ref('nginx@sha256:abc123')
assert_eq $dg->{digest}, "sha256:abc123", "parse_image_ref: digest split off"

# build_image_ref: inverse of parse_image_ref.
assert_eq K8s::build_image_ref("nginx", tag => "1.27")->{image}, "nginx:1.27", "build_image_ref: repository + tag"
assert_eq K8s::build_image_ref("p/img", registry => "gcr.io", tag => "1.0", digest => 'sha256:def')->{image}, 'gcr.io/p/img:1.0@sha256:def', "build_image_ref: all parts"
val $pimg = K8s::parse_image_ref("registry.example.com:5000/team/app:v2")
assert_eq K8s::build_image_ref($pimg->{repository}, registry => $pimg->{registry}, tag => $pimg->{tag})->{image}, "registry.example.com:5000/team/app:v2", "build_image_ref: round-trips parse_image_ref"

# resource_ratio: utilization percentage across units.
assert_eq K8s::resource_ratio("512Mi", "1Gi")->{percent}, 50,  "resource_ratio: 512Mi of 1Gi = 50%"
assert_eq K8s::resource_ratio("250m", "1")->{percent},    25,  "resource_ratio: 250m of 1 core = 25%"
assert_eq K8s::resource_ratio("2Gi", "1Gi")->{percent},   200, "resource_ratio: over-commit reported faithfully"
assert_dies fn { K8s::resource_ratio("1Gi", "0") }, "resource_ratio: rejects a zero total"

# pod_status: readiness summary from a Pod object.
val %podobj = (status => {
    phase => "Running",
    conditions => [ { type => "Ready", status => "True" } ],
    containerStatuses => [
        { ready => true,  restartCount => 2 },
        { ready => false, restartCount => 5 },
    ],
})
val $ps = K8s::pod_status(\%podobj)
assert_eq $ps->{phase},            "Running", "pod_status: phase"
assert_ok $ps->{ready},                       "pod_status: Ready condition true"
assert_eq $ps->{ready_containers}, 1,         "pod_status: ready container count"
assert_eq $ps->{total_containers}, 2,         "pod_status: total container count"
assert_eq $ps->{restarts},         7,         "pod_status: summed restarts"

# owner_refs: extract ownerReferences and flag the controller.
val %ownerobj = (metadata => { ownerReferences => [
    { kind => "ReplicaSet", name => "web-abc", uid => "u1", controller => true },
    { kind => "Foo", name => "bar", uid => "u2" },
] })
val $owner = K8s::owner_refs(\%ownerobj)
assert_eq scalar(@{ $owner->{owners} }), 2,         "owner_refs: two owners"
assert_eq $owner->{controller}{name}, "web-abc",    "owner_refs: controller identified"
assert_eq $owner->{owners}[1]{controller}, 0,       "owner_refs: missing controller flag reads false"

# diff_merge_patch: RFC 7386 merge patch from $from to $to.
val %from = (metadata => { labels => { app => "web", tier => "frontend" } }, spec => { replicas => 2, paused => \0 })
val %to   = (metadata => { labels => { app => "web", tier => "backend", env => "prod" } }, spec => { replicas => 3 })
val $patch = K8s::diff_merge_patch(\%from, \%to)
assert_eq $patch->{metadata}{labels}{tier}, "backend", "diff_merge_patch: changed nested value"
assert_eq $patch->{metadata}{labels}{env},  "prod",    "diff_merge_patch: added nested key"
assert_eq $patch->{spec}{replicas},         3,         "diff_merge_patch: changed scalar"
assert_ok !defined($patch->{spec}{paused}),            "diff_merge_patch: removed key becomes null"

# drain_filter: classify pods for a node drain (kubectl eligibility rules).
val @drainpods = (
    { metadata => { name => "web-1", namespace => "default" }, status => { phase => "Running" } },
    { metadata => { name => "kube-proxy-x", namespace => "kube-system", ownerReferences => [ { kind => "DaemonSet", name => "kube-proxy" } ] }, status => { phase => "Running" } },
    { metadata => { name => "static-pod", namespace => "kube-system", annotations => { "kubernetes.io/config.mirror" => "abc" } }, status => { phase => "Running" } },
    { metadata => { name => "job-done", namespace => "default" }, status => { phase => "Succeeded" } },
)
val $drain = K8s::drain_filter(@drainpods)
assert_eq scalar(@{ $drain->{evictable} }), 1,           "drain_filter: only the plain Running pod is evictable"
assert_eq $drain->{evictable}[0]{name}, "web-1",         "drain_filter: evictable pod name"
assert_eq scalar(@{ $drain->{skipped} }), 3,             "drain_filter: three pods skipped"
assert_eq $drain->{skipped}[0]{reason}, "DaemonSet-managed", "drain_filter: DaemonSet reason"

# normalize_quantity: canonicalize a quantity string to its shortest form.
assert_eq K8s::normalize_quantity("1024Mi")->{quantity}, "1Gi",  "normalize_quantity: 1024Mi → 1Gi"
assert_eq K8s::normalize_quantity("0.5")->{quantity},    "500m", "normalize_quantity: 0.5 cores → 500m"
assert_eq K8s::normalize_quantity("1500m")->{quantity},  "1.5",  "normalize_quantity: 1500m → 1.5"
assert_eq K8s::normalize_quantity("1024Mi")->{value}, 1073741824, "normalize_quantity: base value preserved"
assert_dies fn { K8s::normalize_quantity("10Zz") }, "normalize_quantity: rejects unknown suffix"

# container_images: pull images from a workload (init first, de-duplicated).
val %deployobj = (spec => { template => { spec => {
    initContainers => [ { name => "init", image => "busybox:1.36" } ],
    containers     => [
        { name => "app",     image => "nginx:1.27" },
        { name => "sidecar", image => "busybox:1.36" },
    ],
} } })
val $ci = K8s::container_images(\%deployobj)
assert_eq scalar(@{ $ci->{containers} }), 3,        "container_images: three containers"
assert_eq $ci->{containers}[0]{name}, "init",       "container_images: init container first"
assert_ok $ci->{containers}[0]{init},               "container_images: init flagged"
assert_eq scalar(@{ $ci->{images} }), 2,            "container_images: images de-duplicated"
# Bare Pod shape (containers directly under spec).
val %podimg = (spec => { containers => [ { name => "c", image => "redis:7" } ] })
assert_eq K8s::container_images(\%podimg)->{images}[0], "redis:7", "container_images: bare Pod shape"

# condition: read a named status condition tri-state.
val %condobj = (status => { conditions => [
    { type => "Available",   status => "True",  reason => "MinimumReplicasAvailable" },
    { type => "Progressing", status => "False", reason => "ProgressDeadlineExceeded", message => "deadline" },
] })
val $cond = K8s::condition(\%condobj, "available")
assert_ok $cond->{found},                                "condition: case-insensitive type match"
assert_ok $cond->{is_true},                              "condition: True status"
assert_eq $cond->{reason}, "MinimumReplicasAvailable",   "condition: reason surfaced"
assert_eq K8s::condition(\%condobj, "Progressing")->{is_true}, 0, "condition: False is not is_true"
val $missing = K8s::condition(\%condobj, "Ready")
assert_eq $missing->{found}, 0,                          "condition: missing condition found=false"
assert_ok !defined($missing->{status}),                 "condition: missing condition status undef"

# age_seconds: age from metadata.creationTimestamp (epoch → large positive).
val %ageobj = (metadata => { creationTimestamp => "1970-01-01T00:00:00Z" })
assert_ok K8s::age_seconds(\%ageobj)->{age_seconds} > 1000000000, "age_seconds: epoch is decades old"
# A future timestamp clamps to 0 (clock skew), never negative.
val %futureobj = (metadata => { creationTimestamp => "2999-01-01T00:00:00Z" })
assert_eq K8s::age_seconds(\%futureobj)->{age_seconds}, 0, "age_seconds: future timestamp clamps to 0"

test_run
