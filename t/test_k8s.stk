## t/test_k8s.stk — assertion tests for the stryke `K8s` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_k8s.{dylib,so}` on
## `use K8s`. Live tests provision a unique namespace `stryke-test-$$` and
## tear it down at exit; requires a reachable cluster (KUBECONFIG /
## current-context).

use K8s

# ── permission-free: cdylib reachable ───────────────────────────────
val $pkg_version = K8s::pkg_version()
assert_ok $pkg_version, "K8s::pkg_version returns truthy (cdylib loaded)"

# ── cluster liveness + write-permission probe ───────────────────────
# Connected clusters without RBAC for namespace patch are common (GKE
# read-only auth); guard the live block so a forbidden apply doesn't
# pollute the test report — eval the probe and the whole block.
val $alive = eval { K8s::ping() && eval { K8s::apply({
    apiVersion => "v1", kind => "Namespace",
    metadata => { name => "stryke-test-probe-$$" },
}); K8s::delete_resource("namespace", "stryke-test-probe-$$"); 1 } }

if ($alive) {
    val $ns = "stryke-test-$$"

    # 1. apply Namespace
    val $ns_obj = K8s::apply({
        apiVersion => "v1",
        kind       => "Namespace",
        metadata   => { name => $ns, labels => { "stryke.io/test" => "1" } },
    })
    assert_eq $ns_obj->{metadata}{name}, $ns, "apply Namespace: name preserved"

    # 2. version
    val $v = K8s::version()
    assert_ok defined $v->{gitVersion}, "version returns gitVersion"

    # 3. apply ConfigMap
    val $cm = K8s::apply({
        apiVersion => "v1",
        kind       => "ConfigMap",
        metadata   => { name => "cfg", namespace => $ns },
        data       => { hello => "world", lang => "stryke" },
    })
    assert_eq $cm->{data}{hello}, "world", "apply ConfigMap: hello=world"

    # 4. get configmaps (list)
    val @cms = K8s::get("configmaps", namespace => $ns)
    val $found_cm = grep { $_->{metadata}{name} eq "cfg" } @cms
    assert_ok $found_cm, "get configmaps: includes cfg"

    # 5. get-one configmap
    val $one = K8s::get_one("configmaps", "cfg", namespace => $ns)
    assert_eq $one->{data}{lang}, "stryke", "get_one ConfigMap: data.lang"

    # 6. apply Deployment
    val $dep = K8s::apply({
        apiVersion => "apps/v1",
        kind       => "Deployment",
        metadata   => { name => "sleeper", namespace => $ns },
        spec       => {
            replicas => 1,
            selector => { matchLabels => { app => "sleeper" } },
            template => {
                metadata => { labels => { app => "sleeper" } },
                spec     => {
                    containers => [{
                        name    => "main",
                        image   => "busybox:latest",
                        command => ["sh", "-c", "sleep 3600"],
                    }],
                },
            },
        },
    })
    assert_ok defined $dep->{metadata}{name}, "apply Deployment: metadata.name present"

    # 7. scale Deployment to 2
    val $scaled = K8s::scale("deploy", "sleeper", 2, namespace => $ns)
    assert_eq $scaled->{spec}{replicas}, 2, "scale: replicas=2"

    # 8. api_resources includes core/v1/Pod
    val @ar = K8s::api_resources()
    val $found_pod = grep { $_->{kind} eq "Pod" && $_->{version} eq "v1" } @ar
    assert_ok $found_pod, "api_resources: includes core/v1/Pod"

    # 9. delete Namespace (cascades everything)
    val $del = K8s::delete_resource("namespace", $ns)
    assert_match qr/Deleting|Done/, $del->{status}, "delete Namespace: status Deleting/Done"
}

# ── pure helpers (no cluster — always run) ───────────────────────────
assert_ok K8s::valid_name("my-app.v2")->{valid}, "valid_name: subdomain accepts dots"
val $lbl = K8s::valid_name("my.app", mode => "label")
assert_eq $lbl->{valid}, 0, "valid_name: label mode rejects dots"
assert_eq K8s::valid_name("MyApp")->{valid}, 0, "valid_name: rejects uppercase"

# valid_label_value: label VALUE rules (distinct from names — empty/uppercase/_ ok).
assert_ok K8s::valid_label_value("")->{valid},           "valid_label_value: empty is valid"
assert_ok K8s::valid_label_value("Production")->{valid}, "valid_label_value: uppercase allowed"
assert_ok K8s::valid_label_value("v1.2.3")->{valid},     "valid_label_value: dots and digits"
assert_ok K8s::valid_label_value("my_value-1")->{valid}, "valid_label_value: underscore and dash allowed"
assert_eq K8s::valid_label_value("-bad")->{valid}, 0,    "valid_label_value: must start alphanumeric"
assert_eq K8s::valid_label_value("a b")->{valid}, 0,     "valid_label_value: rejects spaces"
val $tl = K8s::valid_label_value("a" x 64)
assert_eq $tl->{valid}, 0,                               "valid_label_value: over 63 chars fails"
assert_match qr/63/, $tl->{reason},                      "valid_label_value: reason names the limit"

# valid_label_key: label/annotation KEY rules (IsQualifiedName) — optional prefix.
assert_ok K8s::valid_label_key("app")->{valid},                     "valid_label_key: bare name"
val $lk = K8s::valid_label_key("app.kubernetes.io/name")
assert_ok $lk->{valid},                                             "valid_label_key: prefixed key valid"
assert_eq $lk->{prefix}, "app.kubernetes.io",                       "valid_label_key: prefix split out"
assert_eq $lk->{name},   "name",                                    "valid_label_key: name split out"
assert_eq K8s::valid_label_key("a/b/c")->{valid}, 0,               "valid_label_key: rejects two slashes"
assert_eq K8s::valid_label_key("UPPER.PREFIX/name")->{valid}, 0,   "valid_label_key: prefix must be lowercase DNS subdomain"
assert_eq K8s::valid_label_key("-bad")->{valid}, 0,                "valid_label_key: name must start alphanumeric"

val @reqs = K8s::parse_selector("app=nginx,tier!=frontend,!canary")
assert_eq scalar(@reqs), 3,            "parse_selector: three requirements"
assert_eq $reqs[0]{key}, "app",        "parse_selector: equality key"
assert_eq $reqs[0]{op},  "Equal",      "parse_selector: equality op"
assert_eq $reqs[1]{op},  "NotEqual",   "parse_selector: not-equal op"
assert_eq $reqs[2]{op},  "DoesNotExist", "parse_selector: !key existence"

val @setb = K8s::parse_selector("env in (prod,staging)")
assert_eq scalar(@setb), 1,                "parse_selector: paren comma stays together"
assert_eq $setb[0]{op}, "In",              "parse_selector: set-based In"
assert_eq scalar(@{ $setb[0]{values} }), 2, "parse_selector: two set values"

# build_selector: inverse of parse_selector across all operator forms.
val $sel = K8s::build_selector([
    +{ key => "app",  op => "Equal",    value  => "nginx" },
    +{ key => "tier", op => "NotEqual", value  => "frontend" },
    +{ key => "env",  op => "In",       values => ["prod", "staging"] },
    +{ key => "canary", op => "Exists" },
    +{ key => "legacy", op => "DoesNotExist" },
])
assert_eq $sel, "app=nginx,tier!=frontend,env in (prod,staging),canary,!legacy", "build_selector: all operator forms"
# Round-trips: build → parse reproduces the requirement count.
assert_eq scalar(@{ [ K8s::parse_selector($sel) ] }), 5, "build_selector → parse_selector round-trips"
assert_dies fn { K8s::build_selector([ +{ key => "x", op => "Bogus" } ]) }, "build_selector: rejects unknown op"

# selector_matches: evaluate a label map against a selector (apimachinery rules).
val %pod = (app => "nginx", tier => "frontend", env => "prod")
assert_ok  K8s::selector_matches(\%pod, "app=nginx,env in (prod,staging)"), "selector_matches: all requirements satisfied"
assert_eq  K8s::selector_matches(\%pod, "app=nginx,env=dev"), 0,            "selector_matches: one failing requirement fails the selector"
assert_ok  K8s::selector_matches(\%pod, "tier!=backend"),                   "selector_matches: NotEqual with a different value"
assert_eq  K8s::selector_matches(\%pod, "tier!=frontend"), 0,              "selector_matches: NotEqual with the same value fails"
# absent-key rule: NotIn / NotEqual match a missing label; In does not.
assert_ok  K8s::selector_matches(\%pod, "missing notin (a,b)"),             "selector_matches: NotIn matches an absent key"
assert_eq  K8s::selector_matches(\%pod, "missing in (a,b)"), 0,            "selector_matches: In does not match an absent key"
assert_ok  K8s::selector_matches(\%pod, ""),                                "selector_matches: empty selector selects all"

val $rr = K8s::parse_resource_ref("deployment/web")
assert_eq $rr->{kind}, "deployment", "parse_resource_ref: kind"
assert_eq $rr->{name}, "web",        "parse_resource_ref: name"

# parse_quantity: binary memory, milli-CPU, decimal SI, bare/exponent numbers.
val $mem = K8s::parse_quantity("100Mi")
assert_eq $mem->{value},  104857600, "parse_quantity: 100Mi = 100*1024^2 bytes"
assert_eq $mem->{suffix}, "Mi",      "parse_quantity: binary suffix preserved"
val $cpu = K8s::parse_quantity("500m")
assert_eq $cpu->{value}, 0.5,        "parse_quantity: 500m = 0.5 cores"
assert_eq K8s::parse_quantity("2Gi")->{value}, 2147483648, "parse_quantity: 2Gi bytes"
assert_eq K8s::parse_quantity("1k")->{value},  1000,       "parse_quantity: decimal k = 1000"
assert_eq K8s::parse_quantity("1.5")->{value}, 1.5,        "parse_quantity: bare decimal"
assert_eq K8s::parse_quantity("1e3")->{value}, 1000,       "parse_quantity: exponent number"

# compare_quantity: order resource quantities across unit suffixes.
assert_eq K8s::compare_quantity("1Gi", "1024Mi")->{cmp}, 0,  "compare_quantity: 1Gi == 1024Mi"
assert_eq K8s::compare_quantity("500m", "0.5")->{cmp},   0,  "compare_quantity: 500m == 0.5 cores"
assert_eq K8s::compare_quantity("2Gi", "1Gi")->{cmp},    1,  "compare_quantity: 2Gi > 1Gi"
assert_eq K8s::compare_quantity("250m", "1")->{cmp},    -1,  "compare_quantity: 250m < 1 core"
assert_dies fn { K8s::compare_quantity("5Xi", "1") },        "compare_quantity: rejects an unknown suffix"

# format_quantity: inverse of parse_quantity.
assert_eq K8s::format_quantity(104857600, "Mi")->{quantity}, "100Mi", "format_quantity: explicit Mi suffix"
assert_eq K8s::format_quantity(0.5, "m")->{quantity},        "500m",  "format_quantity: milli-CPU"
assert_eq K8s::format_quantity(104857600)->{quantity},      "100Mi", "format_quantity: auto-picks largest binary suffix"
assert_eq K8s::format_quantity(100)->{quantity},            "100",   "format_quantity: bare number when no binary divisor"
# round-trip back through parse_quantity.
assert_eq K8s::parse_quantity(K8s::format_quantity(2147483648)->{quantity})->{value}, 2147483648, "format_quantity → parse_quantity round-trips 2Gi"
assert_dies fn { K8s::format_quantity(1, "Xi") }, "format_quantity: rejects unknown suffix"

# sum_quantities: total a list of quantities across units.
val $sum = K8s::sum_quantities("100Mi", "256Mi", "128Mi")
assert_eq $sum->{count}, 3,          "sum_quantities: counts the inputs"
assert_eq $sum->{quantity}, "484Mi", "sum_quantities: 484Mi total rendered compactly"
assert_eq K8s::sum_quantities("1Gi", "1024Mi")->{quantity}, "2Gi", "sum_quantities: cross-unit 1Gi+1024Mi=2Gi"
assert_eq K8s::sum_quantities("500m", "0.5", "250m")->{value}, 1.25, "sum_quantities: CPU cores total"
assert_dies fn { K8s::sum_quantities() }, "sum_quantities: rejects an empty list"
assert_dies fn { K8s::sum_quantities("100Xi") }, "sum_quantities: rejects an unknown suffix"

test_run
