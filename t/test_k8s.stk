## t/test_k8s.stk — assertion tests for the stryke `K8s` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_k8s.{dylib,so}` on
## `use K8s`. Live tests provision a unique namespace `stryke-test-$$` and
## tear it down at exit; requires a reachable cluster (KUBECONFIG /
## current-context).

use K8s

# ── permission-free: cdylib reachable ───────────────────────────────
val $pkg_version = K8s::pkg_version()
assert_ok $pkg_version, "K8s::pkg_version returns truthy (cdylib loaded)"

# ── cluster liveness + write-permission probe ───────────────────────
# Connected clusters without RBAC for namespace patch are common (GKE
# read-only auth); guard the live block so a forbidden apply doesn't
# pollute the test report — eval the probe and the whole block.
val $alive = eval { K8s::ping() && eval { K8s::apply({
    apiVersion => "v1", kind => "Namespace",
    metadata => { name => "stryke-test-probe-$$" },
}); K8s::delete_resource("namespace", "stryke-test-probe-$$"); 1 } }

if ($alive) {
    val $ns = "stryke-test-$$"

    # 1. apply Namespace
    val $ns_obj = K8s::apply({
        apiVersion => "v1",
        kind       => "Namespace",
        metadata   => { name => $ns, labels => { "stryke.io/test" => "1" } },
    })
    assert_eq $ns_obj->{metadata}{name}, $ns, "apply Namespace: name preserved"

    # 2. version
    val $v = K8s::version()
    assert_ok defined $v->{gitVersion}, "version returns gitVersion"

    # 3. apply ConfigMap
    val $cm = K8s::apply({
        apiVersion => "v1",
        kind       => "ConfigMap",
        metadata   => { name => "cfg", namespace => $ns },
        data       => { hello => "world", lang => "stryke" },
    })
    assert_eq $cm->{data}{hello}, "world", "apply ConfigMap: hello=world"

    # 4. get configmaps (list)
    val @cms = K8s::get("configmaps", namespace => $ns)
    val $found_cm = grep { $_->{metadata}{name} eq "cfg" } @cms
    assert_ok $found_cm, "get configmaps: includes cfg"

    # 5. get-one configmap
    val $one = K8s::get_one("configmaps", "cfg", namespace => $ns)
    assert_eq $one->{data}{lang}, "stryke", "get_one ConfigMap: data.lang"

    # 6. apply Deployment
    val $dep = K8s::apply({
        apiVersion => "apps/v1",
        kind       => "Deployment",
        metadata   => { name => "sleeper", namespace => $ns },
        spec       => {
            replicas => 1,
            selector => { matchLabels => { app => "sleeper" } },
            template => {
                metadata => { labels => { app => "sleeper" } },
                spec     => {
                    containers => [{
                        name    => "main",
                        image   => "busybox:latest",
                        command => ["sh", "-c", "sleep 3600"],
                    }],
                },
            },
        },
    })
    assert_ok defined $dep->{metadata}{name}, "apply Deployment: metadata.name present"

    # 7. scale Deployment to 2
    val $scaled = K8s::scale("deploy", "sleeper", 2, namespace => $ns)
    assert_eq $scaled->{spec}{replicas}, 2, "scale: replicas=2"

    # 8. api_resources includes core/v1/Pod
    val @ar = K8s::api_resources()
    val $found_pod = grep { $_->{kind} eq "Pod" && $_->{version} eq "v1" } @ar
    assert_ok $found_pod, "api_resources: includes core/v1/Pod"

    # 9. delete Namespace (cascades everything)
    val $del = K8s::delete_resource("namespace", $ns)
    assert_match qr/Deleting|Done/, $del->{status}, "delete Namespace: status Deleting/Done"
}

# ── pure helpers (no cluster — always run) ───────────────────────────
assert_ok K8s::valid_name("my-app.v2")->{valid}, "valid_name: subdomain accepts dots"
val $lbl = K8s::valid_name("my.app", mode => "label")
assert_eq $lbl->{valid}, 0, "valid_name: label mode rejects dots"
assert_eq K8s::valid_name("MyApp")->{valid}, 0, "valid_name: rejects uppercase"

val @reqs = K8s::parse_selector("app=nginx,tier!=frontend,!canary")
assert_eq scalar(@reqs), 3,            "parse_selector: three requirements"
assert_eq $reqs[0]{key}, "app",        "parse_selector: equality key"
assert_eq $reqs[0]{op},  "Equal",      "parse_selector: equality op"
assert_eq $reqs[1]{op},  "NotEqual",   "parse_selector: not-equal op"
assert_eq $reqs[2]{op},  "DoesNotExist", "parse_selector: !key existence"

val @setb = K8s::parse_selector("env in (prod,staging)")
assert_eq scalar(@setb), 1,                "parse_selector: paren comma stays together"
assert_eq $setb[0]{op}, "In",              "parse_selector: set-based In"
assert_eq scalar(@{ $setb[0]{values} }), 2, "parse_selector: two set values"

# build_selector: inverse of parse_selector across all operator forms.
val $sel = K8s::build_selector([
    +{ key => "app",  op => "Equal",    value  => "nginx" },
    +{ key => "tier", op => "NotEqual", value  => "frontend" },
    +{ key => "env",  op => "In",       values => ["prod", "staging"] },
    +{ key => "canary", op => "Exists" },
    +{ key => "legacy", op => "DoesNotExist" },
])
assert_eq $sel, "app=nginx,tier!=frontend,env in (prod,staging),canary,!legacy", "build_selector: all operator forms"
# Round-trips: build → parse reproduces the requirement count.
assert_eq scalar(@{ [ K8s::parse_selector($sel) ] }), 5, "build_selector → parse_selector round-trips"
assert_dies fn { K8s::build_selector([ +{ key => "x", op => "Bogus" } ]) }, "build_selector: rejects unknown op"

val $rr = K8s::parse_resource_ref("deployment/web")
assert_eq $rr->{kind}, "deployment", "parse_resource_ref: kind"
assert_eq $rr->{name}, "web",        "parse_resource_ref: name"

# parse_quantity: binary memory, milli-CPU, decimal SI, bare/exponent numbers.
val $mem = K8s::parse_quantity("100Mi")
assert_eq $mem->{value},  104857600, "parse_quantity: 100Mi = 100*1024^2 bytes"
assert_eq $mem->{suffix}, "Mi",      "parse_quantity: binary suffix preserved"
val $cpu = K8s::parse_quantity("500m")
assert_eq $cpu->{value}, 0.5,        "parse_quantity: 500m = 0.5 cores"
assert_eq K8s::parse_quantity("2Gi")->{value}, 2147483648, "parse_quantity: 2Gi bytes"
assert_eq K8s::parse_quantity("1k")->{value},  1000,       "parse_quantity: decimal k = 1000"
assert_eq K8s::parse_quantity("1.5")->{value}, 1.5,        "parse_quantity: bare decimal"
assert_eq K8s::parse_quantity("1e3")->{value}, 1000,       "parse_quantity: exponent number"

test_run
