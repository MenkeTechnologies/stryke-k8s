## t/test_stryke_k8s_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn X::Y::name` declared in lib/*.stk is
## reachable via `use` at runtime. Uses `exists &X::Y::name` to
## probe the symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * a sub-package file dropped from the install layout
##   * `use Foo::Bar` failing to chase into lib/Bar.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no creds, no live daemon. Private
## helpers (`_` prefix) are implementation detail and are NOT
## asserted, so refactoring internals stays free.

use K8s

# ── K8s.stk ──────────────────────────────────────────────
assert_ok exists &K8s::pkg_version, "K8s::pkg_version exists"
assert_ok exists &K8s::version, "K8s::version exists"
assert_ok exists &K8s::ping, "K8s::ping exists"
assert_ok exists &K8s::contexts, "K8s::contexts exists"
assert_ok exists &K8s::current_context, "K8s::current_context exists"
assert_ok exists &K8s::namespaces, "K8s::namespaces exists"
assert_ok exists &K8s::api_resources, "K8s::api_resources exists"
assert_ok exists &K8s::get, "K8s::get exists"
assert_ok exists &K8s::get_one, "K8s::get_one exists"
assert_ok exists &K8s::create, "K8s::create exists"
assert_ok exists &K8s::replace, "K8s::replace exists"
assert_ok exists &K8s::apply, "K8s::apply exists"
assert_ok exists &K8s::patch, "K8s::patch exists"
assert_ok exists &K8s::delete_resource, "K8s::delete_resource exists"
assert_ok exists &K8s::scale, "K8s::scale exists"
assert_ok exists &K8s::logs, "K8s::logs exists"
assert_ok exists &K8s::logs_follow, "K8s::logs_follow exists"
assert_ok exists &K8s::watch, "K8s::watch exists"
assert_ok exists &K8s::exec, "K8s::exec exists"

# ── K8s.stk extras (labels, scheduling, rollouts, events, metrics, wait) ──
assert_ok exists &K8s::annotate, "K8s::annotate exists"
assert_ok exists &K8s::cordon, "K8s::cordon exists"
assert_ok exists &K8s::events, "K8s::events exists"
assert_ok exists &K8s::evict, "K8s::evict exists"
assert_ok exists &K8s::label, "K8s::label exists"
assert_ok exists &K8s::rollout_restart, "K8s::rollout_restart exists"
assert_ok exists &K8s::rollout_status, "K8s::rollout_status exists"
assert_ok exists &K8s::set_image, "K8s::set_image exists"
assert_ok exists &K8s::top_nodes, "K8s::top_nodes exists"
assert_ok exists &K8s::top_pods, "K8s::top_pods exists"
assert_ok exists &K8s::uncordon, "K8s::uncordon exists"
assert_ok exists &K8s::wait, "K8s::wait exists"

assert_ok exists &K8s::rollout_history, "K8s::rollout_history exists"
assert_ok exists &K8s::autoscale, "K8s::autoscale exists"

assert_ok exists &K8s::taint, "K8s::taint exists"
assert_ok exists &K8s::untaint, "K8s::untaint exists"

assert_ok exists &K8s::valid_name, "K8s::valid_name exists"
assert_ok exists &K8s::valid_label_value, "K8s::valid_label_value exists"
assert_ok exists &K8s::valid_label_key, "K8s::valid_label_key exists"
assert_ok exists &K8s::parse_selector, "K8s::parse_selector exists"
assert_ok exists &K8s::build_selector, "K8s::build_selector exists"
assert_ok exists &K8s::parse_field_selector, "K8s::parse_field_selector exists"
assert_ok exists &K8s::build_field_selector, "K8s::build_field_selector exists"
assert_ok exists &K8s::selector_matches, "K8s::selector_matches exists"
assert_ok exists &K8s::field_selector_matches, "K8s::field_selector_matches exists"
assert_ok exists &K8s::parse_resource_ref, "K8s::parse_resource_ref exists"
assert_ok exists &K8s::build_resource_ref, "K8s::build_resource_ref exists"
assert_ok exists &K8s::parse_api_version, "K8s::parse_api_version exists"
assert_ok exists &K8s::build_api_version, "K8s::build_api_version exists"
assert_ok exists &K8s::parse_quantity, "K8s::parse_quantity exists"
assert_ok exists &K8s::compare_quantity, "K8s::compare_quantity exists"
assert_ok exists &K8s::format_quantity, "K8s::format_quantity exists"
assert_ok exists &K8s::sum_quantities, "K8s::sum_quantities exists"
assert_ok exists &K8s::sub_quantity, "K8s::sub_quantity exists"
assert_ok exists &K8s::scale_quantity, "K8s::scale_quantity exists"

# ── K8s.stk new ops (live + pure helpers) ─────────────────
assert_ok exists &K8s::get_yaml, "K8s::get_yaml exists"
assert_ok exists &K8s::exists, "K8s::exists exists"
assert_ok exists &K8s::nodes, "K8s::nodes exists"
assert_ok exists &K8s::delete_collection, "K8s::delete_collection exists"
assert_ok exists &K8s::parse_gvk, "K8s::parse_gvk exists"
assert_ok exists &K8s::build_gvk, "K8s::build_gvk exists"
assert_ok exists &K8s::parse_image_ref, "K8s::parse_image_ref exists"
assert_ok exists &K8s::build_image_ref, "K8s::build_image_ref exists"
assert_ok exists &K8s::resource_ratio, "K8s::resource_ratio exists"
assert_ok exists &K8s::pod_status, "K8s::pod_status exists"
assert_ok exists &K8s::owner_refs, "K8s::owner_refs exists"
assert_ok exists &K8s::diff_merge_patch, "K8s::diff_merge_patch exists"
assert_ok exists &K8s::drain_filter, "K8s::drain_filter exists"

# ── K8s.stk surface expansion (raw/health/scale + pure helpers) ──────
assert_ok exists &K8s::raw, "K8s::raw exists"
assert_ok exists &K8s::healthz, "K8s::healthz exists"
assert_ok exists &K8s::get_scale, "K8s::get_scale exists"
assert_ok exists &K8s::normalize_quantity, "K8s::normalize_quantity exists"
assert_ok exists &K8s::container_images, "K8s::container_images exists"
assert_ok exists &K8s::condition, "K8s::condition exists"
assert_ok exists &K8s::age_seconds, "K8s::age_seconds exists"

test_run
