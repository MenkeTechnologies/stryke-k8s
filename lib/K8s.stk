## lib/K8s.stk — Kubernetes client for stryke (`use K8s`).
##
## Thin wrapper around the `stryke-k8s` cdylib's `k8s__*` exports. The
## cdylib is dlopened in-process on first `use K8s` (see stryke's
## `pkg/commands.rs::try_load_ffi_for`) and registers each export as a
## stryke-callable function via `rust_ffi::load_cdylib`.
##
## Replaces the v1 helper-binary model (fork(2) + exec(2) + fresh TLS+auth
## handshake per call). The cdylib holds:
##   * one shared tokio runtime
##   * a kube::Client cache keyed by kubeconfig context
## Back-to-back calls reuse the same client + underlying HTTP pool.
##
## v0.2.0 surface: 15 core ops (get/get_one, create/replace/apply, delete,
## scale, logs, namespace/api-resource discovery). Streaming ops
## (watch, logs --follow, exec) are deferred — they need a callback FFI
## shape that v1's `FfiSig::StrToStr` doesn't model.

package K8s

# ── error dispatch ────────────────────────────────────────────────────

## Decode the cdylib's JSON return; die on `{error}` payload.
fn K8s::_decode ($name, $json) {
    val $o = from_json $json
    if (ref $o eq "HASH" && exists $o->{error}) {
        die "K8s::$name: $o->{error}"
    }
    $o
}

## Build the FFI request hash by merging the caller's connection opts.
fn K8s::_req ($extra, $opts) {
    var %r = %$extra
    $r{context} = $opts->{context} if exists $opts->{context} && defined $opts->{context}
    \%r
}

# ── version + discovery ──────────────────────────────────────────────

## Return the cdylib's `CARGO_PKG_VERSION` string.
fn K8s::pkg_version {
    K8s::_decode("pkg_version", k8s__pkg_version("{}"))->{version}
}

## Return the package version string.
fn K8s::version (%opts) {
    K8s::_decode("version", k8s__version(to_json(K8s::_req({}, \%opts))))
}

## Connectivity probe — returns 1 on success, 0 on failure.
fn K8s::ping (%opts) {
    val $o = K8s::_decode("ping", k8s__ping(to_json(K8s::_req({}, \%opts))))
    $o->{ok} ? 1 : 0
}

## Array of context names from the kubeconfig.
fn K8s::contexts (%opts) {
    val $o = K8s::_decode("contexts", k8s__contexts(to_json(K8s::_req({}, \%opts))))
    @{ $o->{contexts} }
}

## Active context name from the kubeconfig.
fn K8s::current_context (%opts) {
    K8s::_decode("current_context",
        k8s__current_context(to_json(K8s::_req({}, \%opts))))->{context}
}

## List namespaces (cluster-scoped).
fn K8s::namespaces (%opts) {
    val $o = K8s::_decode("namespaces", k8s__namespaces(to_json(K8s::_req({}, \%opts))))
    @{ $o->{namespaces} }
}

## Array of discoverable kinds with group/version/scope.
fn K8s::api_resources (%opts) {
    val $o = K8s::_decode("api_resources",
        k8s__api_resources(to_json(K8s::_req({}, \%opts))))
    @{ $o->{resources} }
}

# ── get / list ──────────────────────────────────────────────────────

## List resources of $kind in `namespace` (or default). opts: label_selector
## ("app=web"), field_selector ("status.phase=Running"), limit.
fn K8s::get ($kind, %opts) {
    val $r = K8s::_req(
        { kind => $kind, namespace => $opts{namespace},
          label_selector => $opts{label_selector},
          field_selector => $opts{field_selector}, limit => $opts{limit} },
        \%opts)
    val $o = K8s::_decode("get", k8s__get(to_json($r)))
    @{ $o->{items} }
}

## Fetch one resource by $kind + $name.
fn K8s::get_one ($kind, $name, %opts) {
    val $r = K8s::_req(
        { kind => $kind, name => $name, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("get_one", k8s__get_one(to_json($r)))
}

# ── write paths ─────────────────────────────────────────────────────

## Apply a YAML/JSON doc as `create` semantics.
fn K8s::create ($doc, %opts) {
    K8s::_decode("create",
        k8s__create(to_json(K8s::_req({ doc => $doc }, \%opts))))
}

## Replace a resource (must already exist).
fn K8s::replace ($doc, %opts) {
    K8s::_decode("replace",
        k8s__replace(to_json(K8s::_req({ doc => $doc }, \%opts))))
}

## Server-side apply — idempotent declarative reconcile.
fn K8s::apply ($doc, %opts) {
    K8s::_decode("apply",
        k8s__apply(to_json(K8s::_req({ doc => $doc }, \%opts))))
}

## Delete by $kind + $name.
fn K8s::delete_resource ($kind, $name, %opts) {
    val $r = K8s::_req(
        { kind => $kind, name => $name, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("delete", k8s__delete(to_json($r)))
}

## Patch $kind $name with $patch (a hashref). opts: type (merge|strategic,
## default merge), namespace. Returns the patched object.
fn K8s::patch ($kind, $name, $patch, %opts) {
    val $r = K8s::_req(
        { kind => $kind, name => $name, patch => $patch,
          type => ($opts{type} // "merge"), namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("patch", k8s__patch(to_json($r)))
}

## Patch `spec.replicas` to $replicas on $kind $name.
fn K8s::scale ($kind, $name, $replicas, %opts) {
    val $r = K8s::_req(
        { kind => $kind, name => $name, replicas => $replicas, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("scale", k8s__scale(to_json($r)))
}

# ── logs ────────────────────────────────────────────────────────────

## Snapshot logs of a pod. Requires `namespace => $ns`.
fn K8s::logs ($pod, %opts) {
    die "K8s::logs: namespace => 'ns' required" unless defined $opts{namespace}
    val $r = K8s::_req(
        { pod => $pod, namespace => $opts{namespace},
          container => $opts{container}, tail => $opts{tail} },
        \%opts
    )
    K8s::_decode("logs", k8s__logs(to_json($r)))->{logs}
}

## Streaming logs — deferred in v0.2.0 cdylib.
fn K8s::logs_follow ($pod, %opts) {
    die "K8s::logs_follow: streaming ops are deferred in v0.2.0 cdylib"
}

## Streaming resource watch — deferred in v0.2.0 cdylib.
fn K8s::watch ($kind, %opts) {
    die "K8s::watch: streaming ops are deferred in v0.2.0 cdylib"
}

## Streaming exec into pod — deferred in v0.2.0 cdylib.
fn K8s::exec ($pod, $cmd, %opts) {
    die "K8s::exec: streaming ops are deferred in v0.2.0 cdylib"
}

# ── labels / annotations ─────────────────────────────────────────────

## Merge-patch metadata.labels. $labels is a hashref; a key => undef removes it.
fn K8s::label ($kind, $name, $labels, %opts) {
    die "K8s::label: labels must be hashref" unless ref($labels) eq "HASH"
    val $r = K8s::_req(
        { kind => $kind, name => $name, labels => $labels, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("label", k8s__label(to_json($r)))
}

## Merge-patch metadata.annotations. $annotations is a hashref; undef removes.
fn K8s::annotate ($kind, $name, $annotations, %opts) {
    die "K8s::annotate: annotations must be hashref" unless ref($annotations) eq "HASH"
    val $r = K8s::_req(
        { kind => $kind, name => $name, annotations => $annotations, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("annotate", k8s__annotate(to_json($r)))
}

# ── node scheduling ──────────────────────────────────────────────────

## Cordon a node (spec.unschedulable = true).
fn K8s::cordon ($name, %opts) {
    val $r = K8s::_req({ name => $name }, \%opts)
    K8s::_decode("cordon", k8s__cordon(to_json($r)))
}

## Uncordon a node (spec.unschedulable = false).
fn K8s::uncordon ($name, %opts) {
    val $r = K8s::_req({ name => $name }, \%opts)
    K8s::_decode("uncordon", k8s__uncordon(to_json($r)))
}

## Evict a pod (graceful, respects PodDisruptionBudgets). Namespace required.
fn K8s::evict ($name, %opts) {
    die "K8s::evict: namespace => 'ns' required" unless defined $opts{namespace}
    val $r = K8s::_req({ name => $name, namespace => $opts{namespace} }, \%opts)
    K8s::_decode("evict", k8s__evict(to_json($r)))
}

# ── rollouts ─────────────────────────────────────────────────────────

## Set a container's image (strategic merge). opts: kind (default Deployment),
## namespace. $container is the container name to update.
fn K8s::set_image ($name, $container, $image, %opts) {
    val $r = K8s::_req(
        { kind => ($opts{kind} // "Deployment"), name => $name,
          container => $container, image => $image, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("set_image", k8s__set_image(to_json($r)))
}

## Trigger a rolling restart (stamps the pod-template restart annotation).
## opts: kind (default Deployment), namespace.
fn K8s::rollout_restart ($name, %opts) {
    val $r = K8s::_req(
        { kind => ($opts{kind} // "Deployment"), name => $name, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("rollout_restart", k8s__rollout_restart(to_json($r)))
}

## Return a workload's `.status` (replicas / readyReplicas / conditions).
## opts: kind (default Deployment), namespace.
fn K8s::rollout_status ($name, %opts) {
    val $r = K8s::_req(
        { kind => ($opts{kind} // "Deployment"), name => $name, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("rollout_status", k8s__rollout_status(to_json($r)))->{status}
}

# ── events / metrics / wait ──────────────────────────────────────────

## List Events; opts: namespace, name (filter to one object's events), limit.
fn K8s::events (%opts) {
    val $r = K8s::_req(
        { namespace => $opts{namespace}, name => $opts{name}, limit => $opts{limit} },
        \%opts
    )
    @{ K8s::_decode("events", k8s__events(to_json($r)))->{events} }
}

## `top pods` via metrics.k8s.io (needs metrics-server). opts: namespace.
fn K8s::top_pods (%opts) {
    val $r = K8s::_req({ namespace => $opts{namespace} }, \%opts)
    @{ K8s::_decode("top_pods", k8s__top_pods(to_json($r)))->{items} }
}

## `top nodes` via metrics.k8s.io (needs metrics-server).
fn K8s::top_nodes (%opts) {
    val $r = K8s::_req({}, \%opts)
    @{ K8s::_decode("top_nodes", k8s__top_nodes(to_json($r)))->{items} }
}

## Block until $kind/$name meets $condition (a status condition type that
## reads "True", or "delete" for disappearance). opts: namespace, timeout (s).
fn K8s::wait ($kind, $name, %opts) {
    val $r = K8s::_req(
        { kind => $kind, name => $name, condition => ($opts{condition} // "Ready"),
          timeout => $opts{timeout}, namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("wait", k8s__wait(to_json($r)))
}

## Rollout history of Deployment $name: the owned ReplicaSets as
## { name, revision, created, replicas }, newest revision first. opts: namespace.
fn K8s::rollout_history ($name, %opts) {
    val $r = K8s::_req({ name => $name, namespace => $opts{namespace} }, \%opts)
    @{ K8s::_decode("rollout_history", k8s__rollout_history(to_json($r)))->{revisions} }
}

## Create a HorizontalPodAutoscaler targeting $target_name. Required: max.
## opts: name (default target_name), target_kind (default Deployment), min
## (default 1), cpu_percent (default 80), namespace.
fn K8s::autoscale ($target_name, $max, %opts) {
    val $r = K8s::_req(
        { target_name => $target_name, max => $max, name => $opts{name},
          target_kind => ($opts{target_kind} // "Deployment"), min => ($opts{min} // 1),
          cpu_percent => ($opts{cpu_percent} // 80), namespace => $opts{namespace} },
        \%opts
    )
    K8s::_decode("autoscale", k8s__autoscale(to_json($r)))
}

## Add (or replace) a taint on node $name. opts: value, effect (NoSchedule|
## PreferNoSchedule|NoExecute, default NoSchedule). Returns the patched node.
fn K8s::taint ($name, $key, %opts) {
    val $r = K8s::_req(
        { name => $name, key => $key, value => $opts{value},
          effect => ($opts{effect} // "NoSchedule") },
        \%opts
    )
    K8s::_decode("taint", k8s__taint(to_json($r)))
}

## Remove the taint with $key from node $name.
fn K8s::untaint ($name, $key, %opts) {
    val $r = K8s::_req({ name => $name, key => $key, remove => \1 }, \%opts)
    K8s::_decode("untaint", k8s__taint(to_json($r)))
}

# ── pure helpers (no cluster) ─────────────────────────────────────────

## Validate a Kubernetes object name. opts: mode => "subdomain" (default) or
## "label". Returns { name, mode, valid, reason } (reason undef when valid).
fn K8s::valid_name ($name, %opts) {
    K8s::_decode("valid_name", k8s__valid_name(to_json({ name => $name, mode => $opts{mode} })))
}

## Parse a label selector into a list of requirements. Supports equality
## (k=v, k==v, k!=v), set-based (k in (a,b), k notin (a,b)), and existence
## (k, !k). Returns a list of { key, op, value?, values? }.
fn K8s::parse_selector ($selector) {
    @{ K8s::_decode("parse_selector", k8s__parse_selector(to_json({ selector => $selector })))->{requirements} }
}

## Build a label-selector string from a list of requirement hashrefs — inverse
## of parse_selector. Each entry is { key, op, value?|values? } with op one of
## Equal/NotEqual/In/NotIn/Exists/DoesNotExist. Returns the selector string.
fn K8s::build_selector ($requirements) {
    K8s::_decode("build_selector",
        k8s__build_selector(to_json({ requirements => $requirements })))->{selector}
}

## Does a label map (%labels hashref) satisfy a label $selector? All
## requirements are ANDed (apimachinery semantics): In/Equal need the key
## present with the value in set; NotIn/NotEqual match when the key is absent or
## its value is outside the set; Exists/DoesNotExist test presence. An empty
## selector matches everything. Returns true/false.
fn K8s::selector_matches ($labels, $selector) {
    K8s::_decode("selector_matches",
        k8s__selector_matches(to_json({ labels => $labels, selector => $selector })))->{matches}
}

## Parse a kubectl resource ref "kind/name" (or bare "kind") into a hashref
## { kind, name } (name undef when only a kind is given).
fn K8s::parse_resource_ref ($ref) {
    K8s::_decode("parse_resource_ref", k8s__parse_resource_ref(to_json({ ref => $ref })))
}

## Parse a resource quantity ("100Mi", "500m", "2Gi", "1.5", "1e3") into a
## hashref { quantity, number, suffix, value }. Binary suffixes (Ki/Mi/Gi/Ti/
## Pi/Ei) are powers of 1024; decimal suffixes (n/u/m/k/M/G/T/P/E) are powers of
## 1000. `value` is the base-unit amount (bytes for memory, cores for CPU — so
## "500m" yields 0.5).
fn K8s::parse_quantity ($quantity) {
    K8s::_decode("parse_quantity", k8s__parse_quantity(to_json({ quantity => $quantity })))
}

## Render a base-unit $value as a resource quantity string — inverse of
## parse_quantity. With $suffix the value is divided by that suffix's multiplier
## (104857600, "Mi" -> "100Mi"); without one, the largest binary suffix that
## divides exactly is chosen. Returns { quantity, number, suffix, value }.
fn K8s::format_quantity ($value, $suffix = undef) {
    K8s::_decode("format_quantity",
        k8s__format_quantity(to_json({ value => $value, suffix => $suffix })))
}

